/* pages/index/index.wxss — 首页样式 */

.page {
  min-height: 100vh;
  background: #F5F0E8;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ─── 导航栏 ─── */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #FFFFFF;
  font-size: 32rpx;
}

.nav-bar__left { font-size: 40rpx; width: 80rpx; }
.nav-bar__title { font-size: 32rpx; font-weight: 600; color: #1A1A2E; }
.nav-bar__right { width: 80rpx; }

/* ─── 警示条 ─── */
.alert-bar {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
}

.alert-bar--danger { background: #FF6B6B; color: #FFFFFF; }
.alert-bar--warning { background: #FFE66D; color: #7A6000; }

/* ─── 预算卡片 ─── */
.budget-card {
  margin: 24rpx 32rpx 0;
  padding: 28rpx 32rpx 20rpx;
}

.budget-card__row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.budget-card__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.budget-card__divider {
  width: 1rpx;
  height: 48rpx;
  background: #E8E8F0;
}

.budget-card__label {
  font-size: 22rpx;
  color: #6B6B8D;
  margin-bottom: 4rpx;
}

.budget-card__value {
  font-size: 28rpx;
  font-weight: 600;
}

.budget-card__balance-row {
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 16rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #F0F0F0;
}

.budget-card__balance-label { font-size: 22rpx; }

.budget-card__balance {
  font-size: 30rpx;
  font-weight: 700;
}

/* 进度条 */
.budget-progress-bar {
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.budget-progress-bar__fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* ─── 输入卡片 ─── */
.input-card {
  margin: 20rpx 32rpx 0;
  padding: 24rpx;
}

/* 语音区 */
.voice-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #F5F0E8;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  transition: background 0.2s;
}

.voice-area--active { background: #EDE8DE; }

.voice-area__icon { font-size: 64rpx; margin-bottom: 8rpx; }
.voice-area__text { font-size: 26rpx; color: #6B6B8D; }

/* 文字输入框 */
.text-input-wrap {
  background: #F5F5FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.text-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #1A1A2E;
}

/* ─── AI 结果卡片 ─── */
.ai-result-card {
  margin: 20rpx 32rpx 0;
  animation: slideDown 200ms ease-out;
}

@keyframes slideDown {
  from { transform: translateY(-16rpx); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

.ai-result__info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.ai-result__emoji { font-size: 40rpx; }
.ai-result__category { font-size: 28rpx; font-weight: 600; }
.ai-result__amount { font-size: 36rpx; font-weight: 700; margin-left: auto; }
.ai-result__modify { font-size: 24rpx; }

.confirm-btn { margin-top: 4rpx; }

/* ─── 快捷类目 ─── */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  padding: 24rpx 32rpx 12rpx;
}

.section-header {
  padding: 24rpx 32rpx 12rpx;
  align-items: center;
}

.view-all { font-size: 24rpx; }

.quick-categories {
  white-space: nowrap;
  padding: 0 24rpx 12rpx;
}

.quick-cat-item {
  display: inline-flex;
  align-items: center;
  border-radius: 9999rpx;
  padding: 10rpx 24rpx;
  margin: 0 8rpx;
  font-size: 26rpx;
  gap: 8rpx;
}

.quick-cat-item__emoji { font-size: 28rpx; }
.quick-cat-item__name { font-size: 26rpx; }

/* ─── 记录卡片 ─── */
.records-card {
  margin: 0 32rpx;
  padding: 8rpx 24rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.record-item:last-child { border-bottom: none; }

.record-item__emoji { font-size: 40rpx; margin-right: 16rpx; }

.record-item__info { flex: 1; }

.record-item__category { font-size: 28rpx; font-weight: 500; color: #1A1A2E; }
.record-item__remark { font-size: 22rpx; margin-top: 4rpx; }

.record-item__amount { font-size: 28rpx; font-weight: 600; }

/* ─── 骨架屏 ─── */
.skeleton-record {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 16rpx;
}

.skeleton-emoji { width: 56rpx; height: 56rpx; border-radius: 28rpx; flex-shrink: 0; }
.skeleton-text-group { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.skeleton-text { height: 28rpx; width: 120rpx; border-radius: 6rpx; }
.skeleton-text-sm { height: 20rpx; width: 80rpx; border-radius: 6rpx; }
.skeleton-amount { width: 80rpx; height: 28rpx; border-radius: 6rpx; }

/* ─── 新手引导 ─── */
.guide-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.guide-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
  text-align: center;
  margin-bottom: 40rpx;
}

.guide-item {
  background: #F5F0E8;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.guide-item__title { font-size: 28rpx; font-weight: 600; color: #1A1A2E; margin-bottom: 6rpx; }
.guide-item__desc { font-size: 24rpx; color: #3B3B5C; }

.guide-btn { margin: 32rpx 0 0; }
.guide-later {
  text-align: center;
  font-size: 24rpx;
  color: #6B6B8D;
  margin-top: 24rpx;
  padding: 16rpx;
}

/* ─── 金额键盘 bottom-sheet ─── */
.amount-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 300ms ease-out;
  height: 60vh;
  box-sizing: border-box;
}

.amount-sheet.show { transform: translateY(0); }

.amount-sheet__header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.amount-sheet__emoji { font-size: 48rpx; }
.amount-sheet__cat-name { font-size: 32rpx; font-weight: 600; color: #1A1A2E; }
.amount-sheet__value {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B6B;
  margin-left: auto;
}

/* 数字键盘 */
.numpad { display: flex; flex-direction: column; gap: 16rpx; }
.numpad__row { display: flex; gap: 16rpx; }

.numpad__key {
  flex: 1;
  height: 88rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E8F0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A2E;
}

.numpad__key:active { background: #F5F0E8; }

.numpad__key--del { background: #F5F0E8; color: #3B3B5C; }
.numpad__key--del:active { background: #E8E3DA; }
.numpad__key--empty { background: transparent; border: none; pointer-events: none; }

.numpad__key--zero { flex: 2; }

.numpad__confirm {
  flex: 1;
  height: 88rpx;
  background: #7B68EE;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.numpad__confirm:active { background: #6A58D4; }
