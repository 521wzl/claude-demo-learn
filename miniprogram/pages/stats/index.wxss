.container {
  min-height: 100vh;
  background: #F5F0E8;
  padding: 20rpx;
}

.view-tabs {
  display: flex;
  background: #E8E8F0;
  border-radius: 9999rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #6B6B8D;
  border-radius: 9999rpx;
}

.tab.active {
  background: #7B68EE;
  color: #FFFFFF;
}

.overview-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr;
  margin-bottom: 30rpx;
}

.overview-item {
  text-align: center;
  padding: 16rpx 8rpx;
}

.overview-label {
  font-size: 22rpx;
  color: #6B6B8D;
  margin-bottom: 4rpx;
}

.overview-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
}

.overview-value.expense {
  color: #FF6B6B;
}

.overview-value.expense.warning {
  color: #FF4D4F;
}

.overview-value.income {
  color: #4ECDC4;
}

.overview-compare {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.overview-compare.up {
  color: #FF6B6B;
}

.overview-compare.down {
  color: #4ECDC4;
}

.overview-divider {
  width: 1rpx;
  background: #E8E8F0;
  margin: 0;
  align-self: stretch;
}

.chart-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.chart-title {
  font-size: 28rpx;
  color: #1A1A2E;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.pie-chart {
  position: relative;
  height: 350rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.pie-chart canvas {
  width: 300rpx;
  height: 300rpx;
}

.pie-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.pie-center-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1A2E;
  display: block;
}

.pie-center-label {
  font-size: 24rpx;
  color: #6B6B8D;
}

.pie-legend {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  width: 50%;
  margin-bottom: 16rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.legend-text {
  font-size: 24rpx;
  color: #3B3B5C;
}

.line-chart {
  height: 300rpx;
}

.line-chart canvas {
  width: 100%;
  height: 300rpx;
}

.detail-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.detail-title {
  font-size: 28rpx;
  color: #1A1A2E;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.detail-left {
  display: flex;
  align-items: center;
}

.detail-emoji {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.detail-name {
  font-size: 28rpx;
  color: #3B3B5C;
}

.detail-right {
  display: flex;
  align-items: center;
  position: relative;
}

.detail-amount {
  font-size: 28rpx;
  color: #3B3B5C;
  margin-right: 12rpx;
}

.detail-percent {
  font-size: 24rpx;
  color: #6B6B8D;
  width: 80rpx;
  text-align: right;
}

.detail-bar {
  position: absolute;
  bottom: -8rpx;
  left: 0;
  height: 6rpx;
  border-radius: 3rpx;
  opacity: 0.3;
}

.calendar-btn {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.calendar-btn text {
  font-size: 28rpx;
  color: #7B68EE;
}