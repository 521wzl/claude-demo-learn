<view class="container">
  <!-- 视图切换 -->
  <view class="view-tabs">
    <text class="tab {{viewType === 'day' ? 'active' : ''}}" bindtap="switchView" data-type="day">日</text>
    <text class="tab {{viewType === 'week' ? 'active' : ''}}" bindtap="switchView" data-type="week">周</text>
    <text class="tab {{viewType === 'month' ? 'active' : ''}}" bindtap="switchView" data-type="month">月</text>
  </view>

  <!-- 支出概览卡片 -->
  <view class="overview-card">
    <view class="overview-item">
      <text class="overview-label">本月支出</text>
      <text class="overview-value expense {{overBudget ? 'warning' : ''}}">¥{{totalExpense}}</text>
      <text class="overview-compare {{expenseTrend === 'down' ? 'down' : 'up'}}">
        {{expenseTrend === 'down' ? '↓' : '↑'}}{{expenseChange}}
      </text>
    </view>
    <view class="overview-divider"></view>
    <view class="overview-item">
      <text class="overview-label">本月收入</text>
      <text class="overview-value income">¥{{totalIncome}}</text>
      <text class="overview-compare {{incomeTrend === 'down' ? 'down' : 'up'}}">
        {{incomeTrend === 'down' ? '↓' : '↑'}}{{incomeChange}}
      </text>
    </view>
    <view class="overview-divider"></view>
    <view class="overview-item">
      <text class="overview-label">本月结余</text>
      <text class="overview-value {{netAmount >= 0 ? 'income' : 'expense'}}">¥{{netAmount}}</text>
    </view>
  </view>

  <!-- 饼图区域 -->
  <view class="chart-card">
    <text class="chart-title">📊 支出分布</text>
    <view class="pie-chart" bindtap="onPieTap">
      <canvas canvas-id="pieCanvas" id="pieCanvas"></canvas>
      <view class="pie-center">
        <text class="pie-center-value">¥{{totalExpense}}</text>
        <text class="pie-center-label">支出</text>
      </view>
    </view>
    <view class="pie-legend">
      <view class="legend-item" wx:for="{{categoryData}}" wx:key="category" bindtap="onLegendTap" data-category="{{item.category}}">
        <view class="legend-color" style="background:{{item.color}}"></view>
        <text class="legend-text">{{item.emoji}} {{item.category}} {{item.percent}}%</text>
      </view>
    </view>
  </view>

  <!-- 折线图区域 -->
  <view class="chart-card">
    <text class="chart-title">📈 支出趋势</text>
    <view class="line-chart">
      <canvas canvas-id="lineCanvas" id="lineCanvas"></canvas>
    </view>
  </view>

  <!-- 类目明细 -->
  <view class="detail-card">
    <text class="detail-title">类目明细</text>
    <view class="detail-item" wx:for="{{categoryData}}" wx:key="category" bindtap="onCategoryTap" data-category="{{item.category}}">
      <view class="detail-left">
        <text class="detail-emoji">{{item.emoji}}</text>
        <text class="detail-name">{{item.category}}</text>
      </view>
      <view class="detail-right">
        <text class="detail-amount">¥{{item.amount}}</text>
        <text class="detail-percent">{{item.percent}}%</text>
        <view class="detail-bar" style="width:{{item.percent}}%;background:{{item.color}}"></view>
      </view>
    </view>
  </view>

  <!-- 日历入口 -->
  <view class="calendar-btn" bindtap="goToCalendar">
    <text>📅 查看日历</text>
  </view>
</view>