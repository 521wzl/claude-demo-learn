<view class="container">
  <!-- 支出概览卡片 -->
  <view class="overview-card">
    <view class="overview-item">
      <text class="overview-label">本月支出</text>
      <text class="overview-value expense {{overBudget ? 'warning' : ''}}">¥{{totalExpense}}</text>
      <text class="overview-compare {{expenseTrend === 'down' ? 'down' : 'up'}}">
        {{expenseTrend === 'down' ? '↓' : '↑'}}{{expenseChange}}
      </text>
    </view>
    <view class="overview-divider"></view>
    <view class="overview-item">
      <text class="overview-label">本月收入</text>
      <text class="overview-value income">¥{{totalIncome}}</text>
      <text class="overview-compare {{incomeTrend === 'down' ? 'down' : 'up'}}">
        {{incomeTrend === 'down' ? '↓' : '↑'}}{{incomeChange}}
      </text>
    </view>
    <view class="overview-divider"></view>
    <view class="overview-item">
      <text class="overview-label">本月结余</text>
      <text class="overview-value {{netAmount >= 0 ? 'income' : 'expense'}}">¥{{netAmount}}</text>
    </view>
  </view>

  <!-- 类目明细 -->
  <view class="detail-card">
    <text class="detail-title">类目明细</text>
    <view class="detail-item" wx:for="{{fullList}}" wx:key="category" bindtap="onCategoryTap" data-category="{{item.category}}">
      <view class="detail-left">
        <text class="detail-emoji">{{item.emoji}}</text>
        <text class="detail-name">{{item.category}}</text>
      </view>
      <view class="detail-right">
        <text class="detail-amount">¥{{item.amount}}</text>
        <text class="detail-percent">{{item.displayPercent}}%</text>
        <view class="detail-bar" style="width:{{item.percent}}%;background:{{item.color}}"></view>
      </view>
    </view>
  </view>

  <!-- 日历入口 -->
  <view class="calendar-btn" bindtap="goToCalendar">
    <text>📅 查看日历</text>
  </view>
</view>